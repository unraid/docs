{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --port 3001",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint:mdx": "remark . --ext .md,.mdx --quiet --frail",
    "lint": "pnpm run lint:mdx && docusaurus build --out-dir tmp/docusaurus-lint --no-minify",
    "test": "vitest",
    "test:run": "vitest run",
    "prettier": "prettier --write docs",
    "check-case-sensitivity": "node scripts/check-case-sensitivity.js",
    "prebuild": "pnpm run check-case-sensitivity",
    "postinstall": "pnpm rebuild sharp",
    "crowdin:upload": "crowdin upload sources --config crowdin.yml",
    "crowdin:upload:sources": "crowdin upload sources --config crowdin.yml",
    "crowdin:upload:translations": "node scripts/crowdin-upload-translations.js",
    "crowdin:sync": "docusaurus write-translations && crowdin upload sources --config crowdin.yml && crowdin download --config crowdin.yml",
    "crowdin:download": "crowdin download --config crowdin.yml",
    "write-translations": "docusaurus write-translations"
  },
  "dependencies": {
    "@crowdin/cli": "^4.14.1",
    "@docusaurus/core": "3.9.2",
    "@docusaurus/faster": "3.9.2",
    "@docusaurus/plugin-client-redirects": "^3.9.2",
    "@docusaurus/plugin-content-docs": "3.9.2",
    "@docusaurus/plugin-ideal-image": "^3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-common": "3.9.2",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@mdx-js/react": "^3.1.1",
    "@renatonagliati/remark-auto-glossary": "github:renatonagliati/remark-auto-glossary",
    "@tabler/icons-react": "^3.41.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-tooltip": "^6.0.0",
    "semver": "^7.7.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@slorber/remark-comment": "^1.0.0",
    "@tsconfig/docusaurus": "^2.0.9",
    "@types/react": "^19.2.14",
    "glob": "^13.0.6",
    "prettier": "^3.8.3",
    "remark-cli": "^12.0.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint-code-block-style": "^4.0.1",
    "remark-lint-definition-case": "^4.0.1",
    "remark-lint-fenced-code-marker": "^4.0.1",
    "remark-lint-heading-style": "^4.0.1",
    "remark-lint-link-title-style": "^4.0.1",
    "remark-lint-list-item-indent": "^4.0.1",
    "remark-lint-maximum-line-length": "^4.1.1",
    "remark-lint-no-duplicate-definitions": "^4.0.1",
    "remark-lint-no-file-name-outer-dashes": "^3.0.1",
    "remark-lint-no-heading-punctuation": "^4.0.1",
    "remark-lint-no-multiple-toplevel-headings": "^4.0.1",
    "remark-lint-no-shell-dollars": "^4.0.1",
    "remark-lint-no-undefined-references": "^5.0.2",
    "remark-lint-no-unused-definitions": "^4.0.2",
    "remark-lint-ordered-list-marker-style": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.5"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "packageManager": "pnpm@10.33.1"
}
